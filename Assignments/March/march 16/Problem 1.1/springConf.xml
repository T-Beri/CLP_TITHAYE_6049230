<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
	<bean id ="emp1" class="cg.demo.springcore.beans.Employee" >
		<property name="empid" value="1"></property>
		<property name="age" value="22"></property>
		<property name="salary" value="10000"></property>
		<property name="bizzUnit" value="finance"></property>
		<property name="name" value="Tithaye"></property>
	</bean>
	
</beans>